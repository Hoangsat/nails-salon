# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin sign-in uses Supabase Auth email/password accounts created in your project.
# Outside development, only allowlisted emails can access /admin.
ADMIN_ALLOWLIST_EMAILS=

# Demo fallback is available automatically in development.
# Set to true only when you intentionally want demo-mode fallback outside development.
ENABLE_DEMO_MODE=false

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
